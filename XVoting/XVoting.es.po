msgid "xVotingHandler.lmsgKickVoteAdmin"
msgstr ""
"¡%playername% intentó enviar una votación en contra del administrador del "
"servidor!"

msgid "xVotingHandler.lmsgMapWon"
msgstr "¡%mapname% ha ganado la votación!"

msgid "xVotingHandler.lmsgMidGameVote"
msgstr "¡Se ha iniciado la votación de mapas a mitad del juego!"

msgid "xVotingHandler.lmsgSpectatorsCantVote"
msgstr "Lo sentimos, los espectadores no pueden votar."

msgid "xVotingHandler.lmsgMapVotedFor"
msgstr "%playername% ha votado por %mapname%"

msgid "xVotingHandler.lmsgMapVotedForWithCount"
msgstr "%playername% ha colocado %votecount% votos para el mapa %mapname%"

msgid "xVotingHandler.lmsgAdminMapChange"
msgstr "El administrador forzó a cambiar de mapa a %mapname%"
