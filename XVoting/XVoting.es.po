msgid "MapVotingPage.lmsgReplicationNotFinished"
msgstr "Descarga de datos del mapa en curso. Inténtalo de nuevo más tarde."

msgid "MapVotingPage.lmsgMapVotingDisabled"
msgstr ""
"Lo sentimos, el administrador del servidor ha deshabilitado la votación del "
"mapa."

msgid "MapVotingPage.WindowName"
msgstr "Votación por mapas"

msgid "MapVotingPage.lmsgMapDisabled"
msgstr "El mapa seleccionado esta deshabilitado."

msgid "xVotingHandler.lmsgAnonymousKickVote"
msgstr "Se ha emitido un voto de expulsión contra %playername%"

