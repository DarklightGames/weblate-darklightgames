msgid "MapVotingPage.lmsgMapVotingDisabled"
msgstr "Извините, администратор отключил возможность выбора карт голосованием."

msgid "MapVotingPage.lmsgReplicationNotFinished"
msgstr "Данные карты пока ещё загружаются. Пожалуйста попробуйте позже."

msgid "MapVotingPage.lmsgMapDisabled"
msgstr "Выбранная карта отключена."

msgid "MapVotingPage.WindowName"
msgstr "Голосование: карта"

msgid "xVotingHandler.lmsgKickVote"
msgstr ""
"%playername1% запустил голосование об исключении из игры против %playername2%"

msgid "xVotingHandler.lmsgAnonymousKickVote"
msgstr "Против %playername% было запущено голосование об исключении из игры"

msgid "xVotingHandler.lmsgKickVoteAdmin"
msgstr ""
"%playername% попытался запустить голосование об исключении из игры против "
"администратора сервера!"

msgid "xVotingHandler.lmsgMapWon"
msgstr "Победила карта %mapname%!"

msgid "xVotingHandler.lmsgMidGameVote"
msgstr "Было запущено голосование о смене карты посередине игры !!!!"

msgid "xVotingHandler.lmsgSpectatorsCantVote"
msgstr "Извините, зрители не могут голосовать."

msgid "xVotingHandler.lmsgMapVotedFor"
msgstr "%playername% голосует за карту %mapname%"

msgid "xVotingHandler.lmsgMapVotedForWithCount"
msgstr "%playername% разместил %votecount% голосов за карту %mapname%"

msgid "xVotingHandler.lmsgAdminMapChange"
msgstr "Администратор принудительно сменил карту на %mapname%"
